#!/sbin/sh
# Interactive Repartition & Mounting Script for Windows on ARM (Xiaomi Pad 6 / pipa)

clear
echo "=================================================="
echo "    Xiaomi Pad 6 Dual-Boot Partition Utility      "
echo "=================================================="

# Ensure parted and formatting tools exist
for tool in parted mkfs.fat mkfs.ntfs ntfs-3g sgdisk; do
    if ! command -v "$tool" >/dev/null 2>&1 && [ ! -f "/sbin/$tool" ]; then
        echo "Error: Required tool '$tool' is missing from the environment!"
        exit 1
    fi
done

BLOCK_DEV="/dev/block/sda"

# Resize partition table to allow adding new entries safely
echo "[*] Resizing GPT table entries..."
sgdisk --resize-table 64 "$BLOCK_DEV"

# Automatically find userdata start position and current dimensions using parted
USERDATA_LINE=$(parted -s "$BLOCK_DEV" print | grep userdata)
if [ -z "$USERDATA_LINE" ]; then
    echo "Error: Could not automatically detect 'userdata' partition!"
    exit 1
fi

USERDATA_NUM=$(echo "$USERDATA_LINE" | awk '{print $1}')
USER_START=$(echo "$USERDATA_LINE" | awk '{print $2}')
CURRENT_USER_END=$(echo "$USERDATA_LINE" | awk '{print $3}')

# Automatically detect total disk size or maximum available end boundary
MAX_DISK_SIZE=$(parted -s "$BLOCK_DEV" unit GB print | grep "Disk $BLOCK_DEV" | awk '{print $2}')

echo "[+] Detected userdata start at: $USER_START"
echo "[+] Current total storage disk size: $MAX_DISK_SIZE"

# Automatically calculate max safe size for userdata and free space available
START_NUM=$(echo "$USER_START" | sed 's/[^0-9.]//g')
MAX_NUM=$(echo "$MAX_DISK_SIZE" | sed 's/[^0-9.]//g')
AVAILABLE_SPACE=$(awk "BEGIN {print $MAX_NUM - $START_NUM}")

echo "[+] Total available unallocated/disk space from userdata start: ${AVAILABLE_SPACE}GB"

echo ""
echo "--------------------------------------------------"
read -p "Enter your NEW resized size for userdata (e.g., 132.8GB): " USER_END
read -p "Enter your desired WINDOWS size (e.g., 64GB or type 'max' for remaining space): " WIN_SIZE_VAL
echo "--------------------------------------------------"

echo ""
echo "[*] WARNING: This will modify your partition layout on $BLOCK_DEV!"
read -p "Are you sure you want to proceed? (y/N): " CONFIRM
if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
    echo "Aborted by user."
    exit 0
fi

# Calculate ESP endpoints (ESP is fixed at 500MB after userdata)
NUM_VAL=$(echo "$USER_END" | sed 's/[^0-9.]//g')
UNIT=$(echo "$USER_END" | sed 's/[0-9.]//g')

if [ "$UNIT" = "GB" ] || [ "$UNIT" = "gb" ]; then
    ESP_END_VAL=$(awk "BEGIN {print $NUM_VAL + 0.5}")
    ESP_END="${ESP_END_VAL}GB"
else
    ESP_END="${USER_END}"
fi

echo "[*] Removing old userdata partition (Index: $USERDATA_NUM)..."
parted -s "$BLOCK_DEV" rm "$USERDATA_NUM"

echo "[*] Recreating resized userdata partition..."
parted -s "$BLOCK_DEV" mkpart userdata ext4 "$USER_START" "$USER_END"

echo "[*] Creating ESP partition (500MB, FAT32)..."
parted -s "$BLOCK_DEV" mkpart esp fat32 "$USER_END" "$ESP_END"

# Creating Windows partition based on user request
if [ "$WIN_SIZE_VAL" = "max" ] || [ "$WIN_SIZE_VAL" = "MAX" ]; then
    echo "[*] Creating Windows partition (NTFS) using all remaining space (-0MB)..."
    parted -s "$BLOCK_DEV" mkpart win ntfs "$ESP_END" -0MB
else
    WIN_NUM_VAL=$(echo "$WIN_SIZE_VAL" | sed 's/[^0-9.]//g')
    WIN_UNIT=$(echo "$WIN_SIZE_VAL" | sed 's/[0-9.]//g')
    
    if [ "$WIN_UNIT" = "GB" ] || [ "$WIN_UNIT" = "gb" ]; then
        WIN_END_VAL=$(awk "BEGIN {print $ESP_END_VAL + $WIN_NUM_VAL}")
        WIN_END="${WIN_END_VAL}GB"
        echo "[*] Creating Windows partition (NTFS) with size $WIN_SIZE_VAL..."
        parted -s "$BLOCK_DEV" mkpart win ntfs "$ESP_END" "$WIN_END"
    else
        echo "[*] Invalid unit or format. Falling back to remaining space (-0MB)..."
        parted -s "$BLOCK_DEV" mkpart win ntfs "$ESP_END" -0MB
    fi
fi

# Automatically locate and turn on the ESP boot flag
ESP_NUM=$(parted -s "$BLOCK_DEV" print | grep esp | awk '{print $1}')
if [ -n "$ESP_NUM" ]; then
    echo "[*] Turning on boot flag for ESP (Index: $ESP_NUM)..."
    parted -s "$BLOCK_DEV" set "$ESP_NUM" boot on
    parted -s "$BLOCK_DEV" set "$ESP_NUM" esp on
else
    echo "[-] Warning: Could not find ESP index automatically to set flags."
fi

echo "[*] Finalizing partition layout changes..."
parted -s "$BLOCK_DEV" print

echo ""
echo "[*] Formatting new partitions..."
partprobe "$BLOCK_DEV" 2>/dev/null || sleep 2

ESP_PART_PATH=$(ls /dev/block/by-name/esp 2>/dev/null || echo "${BLOCK_DEV}p${ESP_NUM}")
WIN_PART_PATH=$(ls /dev/block/by-name/win 2>/dev/null || echo "${BLOCK_DEV}p$((ESP_NUM + 1))")

if [ -b "$ESP_PART_PATH" ]; then
    mkfs.fat -F32 -s1 "$ESP_PART_PATH" -n "ESP"
    echo "[+] ESP formatted successfully to FAT32."
else
    echo "[-] Warning: Could not locate ESP block node for formatting."
fi

if [ -b "$WIN_PART_PATH" ]; then
    mkfs.ntfs -f "$WIN_PART_PATH" -L "WIN"
    echo "[+] Windows partition formatted successfully to NTFS."
else
    echo "[-] Warning: Could not locate Windows block node for formatting."
fi

# First create win dir in tmp, then mount Windows partition
echo ""
echo "[*] Creating /tmp/win directory..."
mkdir -p /tmp/win

echo "[*] Mounting Windows partition to /tmp/win..."
if [ -b "$WIN_PART_PATH" ]; then
    if command -v ntfs-3g >/dev/null 2>&1; then
        ntfs-3g "$WIN_PART_PATH" /tmp/win
    else
        mount -t ntfs "$WIN_PART_PATH" /tmp/win 2>/dev/null || mount -t ntfs-3g "$WIN_PART_PATH" /tmp/win
    fi
    
    if mountpoint -q /tmp/win; then
        echo "[+] Windows partition successfully mounted at /tmp/win"
    else
        echo "[-] Warning: Failed to mount Windows partition automatically."
    fi
else
    echo "[-] Warning: Windows block path unavailable for mounting."
fi

echo "=================================================="
echo "    Partitioning, Flagging, Formatting & Mounting Done!    "
echo "=================================================="
